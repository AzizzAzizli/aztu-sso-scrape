# Puppeteer üçün rəsmi və içində Chrome olan imici götürürük
FROM ghcr.io/puppeteer/puppeteer:latest

# Root icazəsi alırıq ki, faylları kopyalaya bilək
USER root
WORKDIR /app

# Asılılıqları kopyalayırıq və quraşdırırıq
COPY package*.json ./
RUN npm install

# Bütün proyekt kodlarını kopyalayırıq
COPY . .

# Port ayarı (Railway və ya Koyeb üçün)
ENV PORT=8080
EXPOSE 8080

# Botu başladırıq
CMD ["node", "index.js"]